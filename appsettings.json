{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "your-jwt-secret-key-keep-it-secret-and-change-it-in-production",
    "ExpiresInMinutes": 60
  },
  "Data": {
    "BasePath": "./.data",
    "UsersDbPath": "./.data/users.db",
    "VaultsPath": "./.data/vaults",
    "UserDatabasesPath": "./.data/users"
  },
  "Cloudflare": {
    "Audience": "your-cloudflare-audience",
    "JwksUrl": "https://your-domain.cloudflareaccess.com/cdn-cgi/access/certs"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Authorization",
      "Content-Type",
      "Accept"
    ],
    "AllowCredentials": true,
    "ExposedHeaders": []
  }
}